    "panels": [
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 0
            },
            "id": 1,
            "panels": [],
            "title": "✈️ FLIGHT STATUS - MESH GLOBAL OVERVIEW",
            "type": "row"
        },
        {
            "datasource": "Prometheus",
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "mappings": [],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "orange",
                                "value": 100
                            },
                            {
                                "color": "red",
                                "value": 500
                            }
                        ]
                    },
                    "unit": "reqps"
                }
            },
            "gridPos": {
                "h": 6,
                "w": 6,
                "x": 0,
                "y": 1
            },
            "id": 2,
            "options": {
                "orientation": "auto",
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                },
                "showThresholdLabels": false,
                "showThresholdMarkers": true
            },
            "title": "GLOBAL OPS (RPS)",
            "type": "gauge",
            "targets": [
                {
                    "expr": "sum(irate(istio_requests_total{reporter=\"destination\"}[1m]))",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": "Prometheus",
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 95
                            },
                            {
                                "color": "green",
                                "value": 99.5
                            }
                        ]
                    },
                    "unit": "percent"
                }
            },
            "gridPos": {
                "h": 6,
                "w": 6,
                "x": 6,
                "y": 1
            },
            "id": 3,
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "mean"
                    ]
                }
            },
            "title": "SUCCESS RATE",
            "type": "gauge",
            "targets": [
                {
                    "expr": "sum(irate(istio_requests_total{reporter=\"destination\", response_code=~\"2.*\"}[1m])) / sum(irate(istio_requests_total{reporter=\"destination\"}[1m])) * 100",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": "Prometheus",
            "gridPos": {
                "h": 12,
                "w": 12,
                "x": 12,
                "y": 1
            },
            "id": 4,
            "title": "LATENCY HEATMAP (FLIGHT TURBULENCE)",
            "type": "heatmap",
            "targets": [
                {
                    "expr": "sum(irate(istio_request_duration_milliseconds_bucket{reporter=\"destination\"}[1m])) by (le)",
                    "format": "heatmap",
                    "refId": "A"
                }
            ]
        }
    ],
    "schemaVersion": 27,
    "style": "dark",
    "tags": [

// 💎 SOVEREIGN DATA SCHEMA
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Agency {
  id              String     @id @default(uuid())
  name            String
  logoUrl         String?
  description     String?    @db.Text
  commissionRate  Float      @default(15.0) // Platform takes 15% from this agency
  isVerified      Boolean    @default(false)
  status          String     @default("PENDING") // PENDING, APPROVED, SUSPENDED
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  properties      Property[]
  staff           User[]     // Internal agents/admins for this agency
}

model Property {
  id          String   @id @default(uuid())
  title       String
  price       Float
  address     String
  lat         Float
  lng         Float
  description String?  @db.Text
  has3D       Boolean  @default(false)
  category    String   @default("buy") // 'buy' or 'rent'
  isVIP       Boolean  @default(false)
  videoUrl    String?  // Short-form video URL (TikTok/Reels style)
  
  agencyId    String?  // Links the property to the agency managing it
  agency      Agency?  @relation(fields: [agencyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  images      Image[]
  bookings    Booking[]
  reviews     Review[]
  amenities   String   @default("[]") // JSON string of amenities
  maxGuests   Int      @default(2)

  @@index([price])
  @@index([agencyId])
}

model Image {
  id         String   @id @default(uuid())
  publicId   String
  url        String
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Booking {
  id          String   @id @default(uuid())
  startDate   DateTime
  endDate     DateTime
  totalPrice  Float
  status      String   @default("pending") // pending, confirmed, cancelled
  guestId     String
  guest       User     @relation(fields: [guestId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Review {
  id          String   @id @default(uuid())
  rating      Int
  comment     String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model User {
  id                String    @id @default(uuid())
  name              String
  email             String    @unique
  password          String
  role              String    @default("CUSTOMER") // ADMIN, AGENT, CUSTOMER
  
  // Agency Relation (Only populated if role is AGENCY_ADMIN or AGENT)
  agencyId          String?
  agency            Agency?   @relation(fields: [agencyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // 2FA
  twoFactorSecret   String?
  twoFactorEnabled  Boolean   @default(false)
  
  // Password Reset
  resetPasswordToken String?
  resetPasswordExpires DateTime?

  // JWT Management
  jwtSecretRevision Int       @default(1)
  
  // Relations
  reviews           Review[]
  bookings          Booking[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// Role enum removed for SQLServer compatibility
